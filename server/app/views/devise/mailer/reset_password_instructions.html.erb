<!DOCTYPE html>
<% reset_url = "#{ENV['UI_HOST']}/reset-password?reset_password_token=#{@token}" %>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html charset=UTF-8" />
  </head>
  <body style="margin: 0; text-align: center; padding: 20px">
    <div style="display: flex; justify-content: center; align-items: center; width: 100%; height: 100%;">
      <table style="margin: 0; padding: 0; border-collapse: collapse">
        <tr>
          <td valign="middle">
            <table
              style="
                width: 100%;
                max-width: 600px;
                background: #f9fafb;
                padding: 20px;
                border-radius: 12px;
                border: 1px #eaecf0 solid;
              "
            >
              <tr>
                <td style="text-align: center; padding: 12px">
                  <img
                    src="https://res.cloudinary.com/dspflukeu/image/upload/v1746630317/Multiwoven/ais-logo_fyn2uv.png"
                    style="width: 100%; max-width: 178px"
                    alt="AI Squared Logo"
                  />
                </td>
              </tr>
              <tr>
                <td
                  style="
                    background: white;
                    border-radius: 8px;
                    border: 1px #eaecf0 solid;
                    padding: 48px 16px;
                    text-align: center;
                  "
                >
                  <h1
                    style="
                      color: #101828;
                      font-size: 28px;
                      font-family: Helvetica, Arial, sans-serif;
                      font-weight: 700;
                      line-height: 36px;
                      margin: 0;
                    "
                  >
                    Reset your password
                  </h1>
                  <p
                    style="
                      color: #475467;
                      font-size: 14px;
                      font-family: Helvetica, Arial, sans-serif;
                      font-weight: 400;
                      line-height: 20px;
                    "
                  >
                    A password change has been requested for your account. If this
                    was you, please use the link below to reset your password.
                  </p>
                  <a
                    href="<%= reset_url %>"
                    style="
                      background: #00249c;
                      border-radius: 6px;
                      color: white;
                      display: inline-block;
                      font-size: 14px;
                      font-family: Helvetica, Arial, sans-serif;
                      font-weight: 700;
                      line-height: 20px;
                      padding: 10px 20px;
                      text-decoration: none;
                    "
                  >
                    Reset Password
                  </a>
                </td>
              </tr>
              <tr>
                <td style="padding: 12px; text-align: center">
                  <p
                    style="
                      color: #98a2b3;
                      font-size: 14px;
                      font-family: Helvetica, Arial, sans-serif;
                      font-weight: 400;
                      line-height: 20px;
                      margin: 0;
                    "
                  >
                    This link will expire on <%= (@resource.reset_password_sent_at + Devise.reset_password_within) %>.
                    Please use it to reset your password.
                  </p>
                  <p
                    style="
                      color: #101828;
                      font-size: 14px;
                      font-family: Helvetica, Arial, sans-serif;
                      font-weight: 700;
                      line-height: 20px;
                      margin: 0;
                    "
                  >
                    <br />Cheers,<br />Team AI Squared
                  </p>
                </td>
              </tr>
              <tr>
                <td
                  style="
                    padding: 12px;
                    text-align: center;
                    font-size: 12px;
                    color: #98a2b3;
                    font-family: Helvetica, Arial, sans-serif;
                    line-height: 18px;
                  "
                >
                  <p style="margin: 0 0 8px 0">
                    <a href="https://blog.squared.ai/" style="color: #98a2b3; text-decoration: underline">Our Blog</a>
                    |
                    <a href="https://docs.squared.ai/" style="color: #98a2b3; text-decoration: underline">Docs</a>
                    |
                    <a href="https://squared.ai/contact/" style="color: #98a2b3; text-decoration: underline">Contact Us</a>
                  </p>
                  <p style="margin: 0">
                    AI Squared, 147 Castro Street, Second Floor
                    <br />
                    Mountain View, CA 94041
                  </p>
                  <p style="margin: 0">
                    © <%= Time.current.year %> AI Squared. All Rights Reserved.
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
